"use client";
import Link from "next/link";
import { motion, useReducedMotion, type Variants } from "framer-motion";
import CountUp from "@/components/CountUp";
import { HoverLift } from "@/components/Motion";

/**
 * Section 4 — WHAT YOUR GIFT DOES. Identical light markup + copy. Motion:
 * the real ₹ amounts count up (CountUp, prefix ₹) when scrolled into view,
 * cards reveal with a micro-interaction, Give buttons keep HoverLift.
 * CountUp already renders the final value under reduced-motion.
 */

const GIFTS = [
  { amount: "₹2,500", value: 2500, outcome: "Two weeks of warm meals for a rescued animal getting back on its feet.", cta: "Give ₹2,500" },
  { amount: "₹5,000", value: 5000, outcome: "A full month of food and care for 2–3 animals in our shelter.", cta: "Give ₹5,000" },
  { amount: "₹10,000", value: 10000, outcome: "Emergency medical treatment — the surgery or care that saves a life.", cta: "Give ₹10,000" },
];

const EASE: [number, number, number, number] = [0.16, 1, 0.3, 1];

export function GiftSection() {
  const reduce = useReducedMotion();
  const container: Variants = { hidden: {}, show: { transition: { staggerChildren: reduce ? 0 : 0.08 } } };
  const card: Variants = reduce
    ? { hidden: { opacity: 1, y: 0 }, show: { opacity: 1, y: 0 } }
    : { hidden: { opacity: 0, y: 22 }, show: { opacity: 1, y: 0, transition: { duration: 0.5, ease: EASE } } };

  return (
    <section className="py-20 sm:py-28">
      <div className="container-c">
        <motion.div
          initial={{ opacity: 0, y: 12 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: "0px 0px -10% 0px" }}
          transition={{ duration: reduce ? 0 : 0.4, ease: EASE }}
        >
          <p className="eyebrow text-center">What Your Gift Does</p>
          <h2 className="h-display mx-auto mt-3 max-w-2xl text-center text-3xl sm:text-4xl lg:text-5xl">
            No vague promises. Here&apos;s exactly what your money buys.
          </h2>
        </motion.div>
        <motion.div
          className="mt-12 grid gap-5 sm:grid-cols-3"
          variants={container}
          initial="hidden"
          whileInView="show"
          viewport={{ once: true, margin: "0px 0px -10% 0px" }}
        >
          {GIFTS.map((g) => (
            <motion.div key={g.amount} variants={card} className="card flex h-full flex-col p-7">
              <div className="text-3xl font-semibold text-copper-dark">
                <CountUp to={g.value} prefix="₹" duration={1.1} />
              </div>
              <p className="mt-3 flex-1 text-sm leading-relaxed text-ink/70">{g.outcome}</p>
              <HoverLift className="mt-6 w-full">
                <Link href="/donate-now#donation" className="btn-dark w-full justify-center">{g.cta}</Link>
              </HoverLift>
            </motion.div>
          ))}
        </motion.div>
        <motion.p
          className="mt-7 text-center text-sm text-ink/55"
          initial={{ opacity: 0, y: 10 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: "0px 0px -10% 0px" }}
          transition={{ duration: reduce ? 0 : 0.4, ease: EASE }}
        >
          Give any amount you choose on the{" "}
          <Link href="/donate-now#donation" className="link-secondary">donation page</Link>.
        </motion.p>
      </div>
    </section>
  );
}
