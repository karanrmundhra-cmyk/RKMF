"use client";
import { motion, useReducedMotion, type Variants } from "framer-motion";

/**
 * Section 3 — WHAT WE DO. Identical light bg-snow markup + cards. Motion:
 * cards rise + fade in sequence (stagger 80ms) with a subtle icon pop.
 * Reduced-motion: static final state (variants collapse to no transform).
 */

const WHAT_WE_DO = [
  { title: "Rescue", desc: "When a call comes in about an injured or abandoned animal, we go — to the street, the gutter, wherever they're hurting.", icon: "M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z" },
  { title: "Feed", desc: "Warm meals every single day, so no animal in our care ever has to wonder where the next one comes from.", icon: "M4 20h16M6 20V9a6 6 0 0 1 12 0v11" },
  { title: "Heal", desc: "Wounds dressed, fevers broken, surgeries funded — full medical care with trusted vets until they're whole again.", icon: "M12 4v16m-8-8h16" },
  { title: "Shelter", desc: "A safe, quiet place to rest and recover — where a frightened animal learns that not every human means harm.", icon: "M3 11l9-7 9 7v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9Z" },
];

const EASE: [number, number, number, number] = [0.16, 1, 0.3, 1];

export function WhatWeDo() {
  const reduce = useReducedMotion();
  const container: Variants = { hidden: {}, show: { transition: { staggerChildren: reduce ? 0 : 0.08 } } };
  const card: Variants = reduce
    ? { hidden: { opacity: 1, y: 0 }, show: { opacity: 1, y: 0 } }
    : { hidden: { opacity: 0, y: 22 }, show: { opacity: 1, y: 0, transition: { duration: 0.5, ease: EASE } } };
  const icon: Variants = reduce
    ? { hidden: { opacity: 1, scale: 1 }, show: { opacity: 1, scale: 1 } }
    : { hidden: { opacity: 0, scale: 0.6 }, show: { opacity: 1, scale: 1, transition: { duration: 0.45, ease: EASE, delay: 0.1 } } };

  return (
    <section className="bg-snow py-20 sm:py-28">
      <div className="container-c">
        <motion.div
          initial={{ opacity: 0, y: 12 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true, margin: "0px 0px -10% 0px" }}
          transition={{ duration: reduce ? 0 : 0.4, ease: EASE }}
        >
          <p className="eyebrow text-center">What We Do</p>
          <h2 className="h-display mt-3 text-center text-3xl sm:text-4xl lg:text-5xl">Four ways we show up for animals</h2>
        </motion.div>
        <motion.div
          className="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"
          variants={container}
          initial="hidden"
          whileInView="show"
          viewport={{ once: true, margin: "0px 0px -10% 0px" }}
        >
          {WHAT_WE_DO.map((w) => (
            <motion.div key={w.title} variants={card} className="card h-full p-6">
              <motion.div variants={icon} className="grid h-11 w-11 place-items-center rounded-xl bg-copper/15 text-copper-dark">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round" aria-hidden><path d={w.icon} /></svg>
              </motion.div>
              <h3 className="mt-4 text-lg font-semibold">{w.title}</h3>
              <p className="mt-2 text-sm leading-relaxed text-ink/70">{w.desc}</p>
            </motion.div>
          ))}
        </motion.div>
      </div>
    </section>
  );
}
