function PersonCard({ p }: { p: { name: string; role: string; img: string | null } }) {
  const initials = p.name.split(" ").map((w) => w[0]).slice(0, 2).join("");
  return (
    <div className="card p-5 text-center">
      {p.img ? (
        <img src={p.img} alt={p.name} className="mx-auto h-24 w-24 rounded-full object-cover" loading="lazy" />
      ) : (
        <div className="mx-auto grid h-24 w-24 place-items-center rounded-full bg-copper/15 text-xl font-bold text-copper-dark">{initials}</div>
      )}
      <div className="mt-4 font-semibold">{p.name}</div>
      <div className="mt-0.5 text-xs uppercase tracking-wide text-ink/60">{p.role}</div>
    </div>
  );
}

