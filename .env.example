# Email (form submissions) — get a free key at resend.com
RESEND_API_KEY=
FORMS_TO_EMAIL=info@rkm.support
FORMS_FROM_EMAIL=website@rkm.support

# Razorpay — from dashboard.razorpay.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# REQUIRED for 80G receipts. The webhook (POST /api/razorpay-webhook) is the
# ONLY thing that issues the numbered receipt + emails the donor on payment.
# In Razorpay Dashboard -> Settings -> Webhooks: add the URL
#   https://rkmfoundation.com/api/razorpay-webhook
# with events payment.captured + payment.failed (+ subscription.charged for
# monthly), set a secret, and paste the SAME secret here. Without this the
# payment still succeeds but NO receipt is ever sent.
RAZORPAY_WEBHOOK_SECRET=

# Supabase (compliance spine)
SUPABASE_URL=https://rnwifjrdhdhemrlmgjij.supabase.co
SUPABASE_SERVICE_KEY=   # Dashboard -> Settings -> API -> service_role (KEEP SECRET)
DEFAULT_FUND_ID=        # fund_id of 'Animal Welfare' fund

# Admin console (M3 interim auth) — any long random string; staff send it as
# the x-admin-token header / paste it on /admin. Replaced by Supabase Auth in M4.
ADMIN_ACCESS_TOKEN=

# Analytics (SOP-02) — cookieless, consent-gated. Loads only after the visitor
# accepts analytics in the cookie banner. Defaults target Plausible Cloud for
# rkmfoundation.com, so these are optional; override only to change domain or to
# self-host/proxy the script (also update plausible.io in next.config.mjs CSP).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=rkmfoundation.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
